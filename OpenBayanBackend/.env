# ============================================================
# kaig - Knowledge Graph Environment Config
# Using remote Ollama server at 100.75.239.40
# ============================================================

# SurrealDB Connection (matches docker-compose.yml: port 8100, root/root)
SURREALDB_URL=ws://127.0.0.1:8100
SURREALDB_NAMESPACE=kaig
SURREALDB_DATABASE=knowledge_graph
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root

# ============================================================
# Ollama Config (Remote Server)
# ============================================================
OLLAMA_URL=http://100.121.116.17:11434
OLLAMA_HOST=http://100.121.116.17:11434

# LLM model (for concept extraction, summarization, Q&A)
OLLAMA_LLM_MODEL=llama3.1:latest

# Embedding model (for vector search in SurrealDB)
OLLAMA_EMBED_MODEL=mxbai-embed-large:latest

# Translation model
OLLAMA_TRANSLATE_MODEL=aya:latest

# Transliteration model
OLLAMA_TRANSLITERATE_MODEL=aya:latest

# ============================================================
# SSH Access to Ollama Server (for pulling new models)
# ssh smkmustaqbal@100.121.116.17
# Usage: ollama pull <model>
# ============================================================
OLLAMA_SSH_USER=smkmustaqbal
OLLAMA_SSH_PASSWORD=Mustaqbal_153##
OLLAMA_SSH_HOST=100.121.116.17

# Optional: Logfire tracing (leave blank to disable)
# LOGFIRE_TOKEN=
