 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🧠 OpenBayan: Taxonomy-Driven Enrichment Research\n",
    "\n",
    "This notebook implements **Categorization-First Enrichment** using your custom taxonomy.\n",
    "\n",
    "## Key Features:\n",
    "1. **Hierarchical Categorization**: Assigns segments to specific levels of the Quranic/Hadith sciences taxonomy.\n",
    "2. **Smart Filtering**: LLM picks from valid taxonomy paths.\n",
    "3. **Knowledge Graph Linking**: Relates segments and entities to their respective scholarly domains."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import json\n",
    "from typing import List, Optional\n",
    "from pydantic import BaseModel, Field\n",
    "from surrealdb import Surreal\n",
    "\n",
    "OLLAMA_URL = \"http://100.121.116.17:11434\"\n",
    "SURREAL_URL = \"ws://surrealdb:8000/rpc\"\n",
    "MODEL = \"qwen2.5:7b\"\n",
    "EMBED_MODEL = \"mxbai-embed-large:latest\"\n",
    "\n",
    "print(\"Setup complete.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Get Taxonomy Context\n",
    "We pull the taxonomy from SurrealDB to provide the LLM with valid choices."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_taxonomy_paths():\n",
    "    with Surreal(SURREAL_URL) as db:\n",
    "        db.signin({\"user\": \"root\", \"pass\": \"root\"})\n",
    "        db.use(\"main\", \"main\")\n",
    "        \n",
    "        # Simple query to get leaf nodes or deep nodes\n",
    "        res = db.query(\"SELECT id, label, level FROM alamah WHERE level >= 3 ORDER BY level ASC;\")\n",
    "        return [{\"id\": r[\"id\"], \"label\": r[\"label\"]} for r in res[0][\"result\"]]\n",
    "\n",
    "TAXONOMY_CANDIDATES = get_taxonomy_paths()\n",
    "print(f\"Loaded {len(TAXONOMY_CANDIDATES)} scholarly categories for enrichment.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Enrichment Models\n",
    "We add `taxonomy_id` to link back to our canonical categories."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class Entity(BaseModel):\n",
    "    name: str\n",
    "    type: str\n",
    "    role: str\n",
    "\n",
    "class Categorization(BaseModel):\n",
    "    taxonomy_label: str = Field(description=\"Selected category name from provided taxonomy\")\n",
    "    confidence: float\n",
    "    reasoning: str\n",
    "\n",
    "class EnrichmentResult(BaseModel):\n",
    "    categorization: Categorization\n",
    "    entities: List[Entity]\n",
    "    summary: str"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Knowledge Extraction\n",
    "The LLM acts as an editor matching text to taxonomy."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def enrich_text(text: str) -> Optional[EnrichmentResult]:\n",
    "    categories_str = \"\\n\".join([f\"- {c['label']}\" for c in TAXONOMY_CANDIDATES])\n",
    "    \n",
    "    prompt = f\"\"\"\n",
    "    Act as an Islamic research scholar.\n",
    "    Analyze this text: {text}\n",
    "    \n",
    "    TASK:\n",
    "    1. Map this text to the most relevant category from the following scholarly taxonomy:\n",
    "    {categories_str}\n",
    "    \n",
    "    2. Extract key entities (Divinity, Prophets, Concepts).\n",
    "    \n",
    "    Return ONLY JSON matching EnrichmentResult schema.\n",
    "    \"\"\"\n",
    "    \n",
    "    res = requests.post(f\"{OLLAMA_URL}/api/generate\", json={\"model\": MODEL, \"prompt\": prompt, \"stream\": False, \"format\": \"json\"})\n",
    "    try:\n",
    "        return EnrichmentResult.parse_raw(res.json()[\"response\"])\n",
    "    except: return None"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Run Pipeline\n",
    "Extract and link to the Knowledge Graph."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "test_ayah = \"اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ\"\n",
    "result = enrich_text(test_ayah)\n",
    "\n",
    "if result:\n",
    "    print(f\"Assigned Category: {result.categorization.taxonomy_label}\")\n",
    "    print(f\"Reasoning: {result.categorization.reasoning}\")\n",
    "    \n",
    "    with Surreal(SURREAL_URL) as db:\n",
    "        db.signin({\"user\": \"root\", \"pass\": \"root\"})\n",
    "        db.use(\"main\", \"main\")\n",
    "        \n",
    "        # 1. Resolve Tag ID from Label\n",
    "        tag_res = db.query(\"SELECT id FROM alamah WHERE label = $label LIMIT 1\", {\"label\": result.categorization.taxonomy_label})\n",
    "        if tag_res and tag_res[0]:\n",
    "            tag_id = tag_res[0][\"id\"]\n",
    "            print(f\"Linking to canonical tag: {tag_id}\")\n",
    "            \n",
    "            # 2. Relate sentence to category\n",
    "            db.query(\n",
    "                \"RELATE sentence:current_chunk->tagged_with->$tag SET weight = $conf\", \n",
    "                {\"tag\": tag_id, \"conf\": result.categorization.confidence}\n",
    "            )"
   ]
  }\n",
 ],\n",
